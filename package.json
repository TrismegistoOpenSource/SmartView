{
  "name": "smartview",
  "version": "0.1.0",
  "description": "Editor PDF desktop minimalista e veloce",
  "main": "./out/main/index.js",
  "author": "Nicolò Evandri",
  "license": "GPL-3.0-or-later",
  "homepage": "https://github.com/TrismegistoOpenSource/SmartView",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TrismegistoOpenSource/SmartView.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "vitest run",
    "test:pdfa": "vitest run src/main/pdf/pdfa.verify.test.ts",
    "verapdf:install": "node scripts/install-verapdf.mjs",
    "icon": "electron scripts/make-icon.cjs resources/icon.png",
    "dist:mac": "npm run dist:mac-arm && npm run dist:mac-intel",
    "dist:mac-arm": "electron-vite build && electron-builder --mac --arm64 -c.appId=com.smartview.desktop.arm64 -c.productName=SmartView-AppleSilicon",
    "dist:mac-intel": "electron-vite build && electron-builder --mac --x64 -c.appId=com.smartview.desktop.intel -c.productName=SmartView-Intel",
    "dist:win": "electron-vite build && electron-builder --win",
    "dist:linux": "electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.5",
    "@pdf-lib/fontkit": "^1.1.1",
    "@tanstack/react-virtual": "^3.14.5",
    "dompurify": "^3.4.11",
    "markdown-it": "^14.3.0",
    "markdown-it-task-lists": "^2.1.1",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "zustand": "^5.0.0"
  }
}
